-- 15 Business Problems & Solutions

--1. Count the number of Movies vs TV Shows

SELECT 
    type,
    COUNT(*) AS Total_number
    FROM netflix
GROUP BY type

--2. Find the most common rating for movies and TV shows

SELECT 
    type,
    rating
FROM 
(
    SELECT 
    type, 
    COUNT(*) AS count_num,
    RANK() OVER(PARTITION BY type ORDER BY COUNT(*) DESC ) AS Ranking_number,
    rating
    FROM Netflix
    GROUP BY type, rating
)t
WHERE Ranking_number = 1



--3. List all movies released in a specific year (e.g., 2020)

SELECT 
    type,
    title,
    release_year
FROM Netflix
    WHERE type = 'Movie' AND release_year = 2020


--4. Find the top 5 countries with the most content on Netflix

SELECT TOP 5 
TRIM(value) AS country,
COUNT(*) AS Most_content
FROM netflix
CROSS APPLY STRING_SPLIT(country, ',') 
GROUP BY TRIM(value) 
ORDER by COUNT(*) DESC

--5. Identify the longest movie

SELECT 
    title,
    duration,
    type
FROM dbo.netflix
WHERE 
    type = 'Movie' AND 
    duration = (SELECT MAX(duration) FROM netflix)



--6. Find content added in the last 5 years

SELECT *,
DATEPART(YEAR, date_added) AS Year_
FROM netflix
WHERE YEAR(date_added) >= YEAR(GETDATE()) - 5
ORDER BY Year_



--7. Find all the movies/TV shows by director 'Rajiv Chilaka'!

SELECT 
    title,director
FROM netflix
    WHERE director LIKE '%Rajiv Chilaka%' AND type = 'movie'



--8. List all TV shows with more than 5 seasons

SELECT * 
FROM netflix
WHERE type = 'TV Show'
  AND TRY_CAST(LEFT(duration, CHARINDEX(' ', duration) - 1) AS INT) > 5;  --- 
--- TRY_CAST= Converts the numeric string to compare with integer 
--- CHARINDEX = Find the exact position of the space character 
-- LEFT () =Grabs the character before the space if -1 consider the backwards number or 1 consider the forward number 
--  LEFT   -3-2,-1,VALUE ,1,2,3   RIGHT 


--9. Count the number of content items in each genre


SELECT 
count(*) AS Number_content,
TRIM(value) AS Genre
FROM netflix 
CROSS APPLY STRING_SPLIT (listed_in, ',')
GROUP BY TRIM(value)
ORDER BY count(*) DESC
-- STRING-SPLIT HELPS TO SEPARATE THE VALUES IN COLUMNS AND MENTION IT IN PARENTHESIS
--  TRIM TO REMOVE THE UNWANTED SPACE IN  THE CELL 


--10.Find each year and the average numbers of content release in India on netflix. return top 5 year with highest avg content release!

SELECT TOP 5
    Year_,
    Total_Count,
    -- Calculate percentage contribution: (Yearly Count / Grand Total) * 100
    ROUND(
        CAST(Total_Count AS FLOAT) / 
        (SELECT COUNT(*) FROM netflix WHERE country = 'India') * 100, 
        2
    ) AS avg_content_per_year
FROM (
    SELECT  
        DATEPART(YEAR, date_added) AS Year_,
        COUNT(*) AS Total_Count
    FROM netflix 
    WHERE country = 'India' AND date_added IS NOT NULL
    GROUP BY DATEPART(YEAR, date_added)
) t
ORDER BY Year_;
-- Calculating average percentage for each year for India country 


