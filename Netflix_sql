--13. Find how many movies actor 'Salman Khan' appeared in last 10 years!


SELECT * FROM netflix
WHERE cast LIKE '%Salman Khan%'
AND release_year > YEAR(GETDATE()) -10
--There is release_year INT and (getdate) DATETIME So We only need year to get to calculate 


--14. Find the top 10 actors who have appeared in the highest number of movies produced in India.


SELECT TOP 10
TRIM(value) AS Actor_name,
COUNT(*) AS Total_content
FROM Netflix
CROSS APPLY String_split(cast, ',') 
WHERE country LIKE '%India'
GROUP BY TRIM(value) 
ORDER BY Total_content DESC
-- STRING_SPLIT to split all the record in the field in arrange them in each row in one single columns 
-- And aggregate with count of total content and filter it with India and order by desc can find the highest number


--15.Categorize the content based on the presence of the keywords 'kill' and 'violence' inthe description field. Label content containing these keywords as 'Bad' and all other content as 'Good'. Count how many items fall into each category.
SELECT
COUNT(*) AS Total_Num_of_content,
Review
FROM(
SELECT *,
CASE WHEN description LIKE '%kill%' THEN 'Bad Content'
     WHEN description LIKE '%violence%' THEN 'Bad Content'
     ELSE 'Good Content'
END AS Review 
FROM netflix
)t 
GROUP BY Review




